# Grantify Environment Variables
# Copy this file to .env and fill in values

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_DEBUG=True
DEMO_MODE=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/grantify

# Email
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=grants@yourdomain.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=grants@yourdomain.com

# Microsoft Entra ID (Azure AD) SSO
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-client-secret
MICROSOFT_TENANT_ID=common

# Mapbox (map view)
MAPBOX_ACCESS_TOKEN=your-mapbox-access-token

# DocuSign e-Signature
DOCUSIGN_INTEGRATION_KEY=your-docusign-integration-key
DOCUSIGN_RSA_KEY_FILE=docusign_private.pem
DOCUSIGN_ACCOUNT_ID=your-docusign-account-id
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi

# Grants.gov API (Simpler Grants.gov — free tier)
# Get a free key at https://simpler.grants.gov
GRANTS_GOV_API_KEY=your-grants-gov-api-key
